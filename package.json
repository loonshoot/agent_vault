{
  "name": "agent-vault",
  "version": "0.1.0",
  "description": "Human-in-the-loop secret access for AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-vault": "dist/index.js"
  },
  "files": [
    "dist",
    "agent-vault.config.example.json",
    ".env.secrets.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "secrets",
    "1password",
    "ai-agent",
    "claude",
    "cursor",
    "approval",
    "vault"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/loonshoot/agent_vault.git"
  },
  "homepage": "https://github.com/loonshoot/agent_vault",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@1password/sdk": "^0.4.0"
  },
  "peerDependenciesMeta": {
    "@1password/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ngrok/ngrok": "^1.7.0",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
